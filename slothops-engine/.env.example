# === SlothOps Engine Environment Variables ===

# ── LLM Providers (free/low-cost fallback chain) ────────────────────────
# SlothOps uses OpenAI-compatible HTTP APIs here, but does not require OpenAI
# or Anthropic credentials. Providers without keys are skipped automatically.
LLM_PROVIDER_CHAIN=freemodel,openrouter,groq,cerebras,together,mistral,github_models,huggingface
LLM_TIMEOUT_SECONDS=120
LLM_MAX_TOKENS=8192
LLM_TEMPERATURE=0.2
# Keep false unless your selected providers accept response_format=json_object.
LLM_SEND_RESPONSE_FORMAT=false

# FreeModel: https://freemodel.dev/
FREEMODEL_API_KEY=
FREEMODEL_BASE_URL=https://freemodel.dev/v1
FREEMODEL_MODELS=FRE-5.5,FRE-5.4

# OpenRouter free routing / free models.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openrouter/free

# Groq free tier.
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant

# Cerebras inference free tier.
CEREBRAS_API_KEY=
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_MODEL=llama3.1-8b

# Together AI free/low-cost models.
TOGETHER_API_KEY=
TOGETHER_BASE_URL=https://api.together.xyz/v1
TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo-Free

# Extra optional providers for local experimentation.
MISTRAL_API_KEY=
MISTRAL_BASE_URL=https://api.mistral.ai/v1
MISTRAL_MODEL=mistral-small-latest
GITHUB_MODELS_TOKEN=
GITHUB_MODELS_BASE_URL=https://models.github.ai/inference
GITHUB_MODELS_MODEL=microsoft/phi-4
HUGGINGFACE_API_KEY=
HUGGINGFACE_BASE_URL=https://router.huggingface.co/v1
HUGGINGFACE_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct

# ── GitHub App Credentials ───────────────────────────────────────────────
GITHUB_APP_ID=12345
GITHUB_APP_PRIVATE_KEY=/path/to/private-key.pem
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# ── PostgreSQL (Docker Compose) ──────────────────────────────────────────
# Start with: docker compose up -d postgres
# Then run:   alembic upgrade head
DATABASE_URL=postgresql+asyncpg://slothops:slothops_dev@localhost:5432/slothops
DIRECT_DATABASE_URL=postgresql+psycopg://slothops:slothops_dev@localhost:5432/slothops

# Legacy SQLite — only used for isolated unit tests, not the dev server
# DATABASE_PATH=./slothops.db

# ── Server ───────────────────────────────────────────────────────────────
PORT=8000
LOG_LEVEL=INFO
BASE_URL=https://your-ngrok-url.ngrok.io

# ── Sentry ───────────────────────────────────────────────────────────────
SENTRY_WEBHOOK_SECRET=whsec_optional

# ── Email (optional — for QA report notifications) ───────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@example.com
# SMTP_PASSWORD=your-app-password
# QA_EMAIL_RECIPIENT=team@example.com

# ── Rollback Defaults (overridable per repo via /api/repos/config) ────────
ROLLBACK_DEFAULT_MODE=approval_required
ROLLBACK_DEFAULT_STRATEGY=rollback_pr
