# === SlothOps Engine Environment Variables ===

# Google Cloud / Vertex AI (required for LLM operations)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# GitHub App Credentials (required for PR automation)
GITHUB_APP_ID=12345
GITHUB_APP_PRIVATE_KEY=/path/to/private-key.pem

# Target GitHub repo in "owner/repo" format
GITHUB_REPO=org/slothops-demo-app

# SQLite database file path
DATABASE_PATH=./slothops.db

# Server port
PORT=8000

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Email (optional — for QA report notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# QA_EMAIL_RECIPIENT=
